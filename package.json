{
  "name": "qitong-lan-portfolio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app src tests next.config.js mdx-components.tsx",
    "format": "prettier --write app src tests content next.config.js eslint.config.mjs mdx-components.tsx playwright.config.ts vitest.config.ts package.json tsconfig.json",
    "format:check": "prettier --check app src tests content next.config.js eslint.config.mjs mdx-components.tsx playwright.config.ts vitest.config.ts package.json tsconfig.json",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check && npm run format:check && npm run test:run",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.10",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.53.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.15.34",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/ui": "4.1.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "4.1.10"
  }
}
